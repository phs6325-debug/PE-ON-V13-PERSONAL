/* =========================================================
   PE-ON v10 LTS SAFE OVERRIDES
   2026-07-08
   목적:
   1) 홈 바로가기 카드/버튼 복구
   2) 진도 수업기록 팝업 삭제/저장 버튼 오른쪽 하단 정렬
   주의: 기존 CSS를 지우지 않고 style.css 맨 아래에서 최종 우선 적용
   ========================================================= */

/* ---------- HOME: 바로가기 카드 복구 ---------- */
.home-page .home-quick-cards,
.home-page .home-quick-cards.home-quick-cards-field{
  display:grid !important;
  grid-template-columns:repeat(6, minmax(0, 1fr)) !important;
  gap:16px !important;
  align-items:stretch !important;
  width:100% !important;
  margin-top:18px !important;
}

.home-page .home-quick-card,
.home-page .home-quick-cards-field .home-quick-card,
.home-page .mobile-field-card,
.home-page .pc-manage-card{
  display:flex !important;
  flex-direction:column !important;
  align-items:center !important;
  justify-content:space-between !important;
  text-align:center !important;
  min-width:0 !important;
  min-height:205px !important;
  height:auto !important;
  padding:20px 16px !important;
  background:#ffffff !important;
  border:1px solid #e5eaf3 !important;
  border-radius:22px !important;
  box-shadow:0 8px 22px rgba(15,23,42,.08) !important;
  overflow:visible !important;
  opacity:1 !important;
  visibility:visible !important;
}

.home-page .home-quick-icon{
  width:56px !important;
  height:56px !important;
  min-width:56px !important;
  min-height:56px !important;
  margin:0 auto 10px !important;
  border-radius:18px !important;
  background:#eff6ff !important;
  color:#2563eb !important;
  font-size:30px !important;
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  line-height:1 !important;
}

.home-page .home-quick-card h3{
  margin:0 0 8px !important;
  font-size:20px !important;
  font-weight:900 !important;
  color:#111827 !important;
  line-height:1.2 !important;
  white-space:nowrap !important;
}

.home-page .home-quick-card p{
  flex:1 1 auto !important;
  display:block !important;
  min-height:40px !important;
  margin:0 0 14px !important;
  color:#64748b !important;
  font-size:14px !important;
  font-weight:700 !important;
  line-height:1.4 !important;
  word-break:keep-all !important;
  overflow:visible !important;
}

.home-page .home-quick-card button{
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:100% !important;
  min-width:0 !important;
  height:46px !important;
  min-height:46px !important;
  margin-top:auto !important;
  padding:0 16px !important;
  border:1.5px solid #10b981 !important;
  border-radius:14px !important;
  background:#ffffff !important;
  color:#047857 !important;
  font-size:15px !important;
  font-weight:900 !important;
  line-height:1 !important;
  white-space:nowrap !important;
  visibility:visible !important;
  opacity:1 !important;
  pointer-events:auto !important;
  position:static !important;
  transform:none !important;
  z-index:auto !important;
}

.home-page .home-quick-card button:hover{
  background:#ecfdf5 !important;
  transform:translateY(-1px) !important;
}

/* 태블릿: 넓은 태블릿은 6개 한 줄 */
@media (min-width:901px) and (max-width:1366px){
  .home-page .home-quick-cards,
  .home-page .home-quick-cards.home-quick-cards-field{
    grid-template-columns:repeat(6, minmax(0, 1fr)) !important;
    gap:12px !important;
  }

  .home-page .home-quick-card{
    min-height:190px !important;
    padding:18px 12px !important;
  }

  .home-page .home-quick-icon{
    width:50px !important;
    height:50px !important;
    min-width:50px !important;
    min-height:50px !important;
    font-size:26px !important;
  }

  .home-page .home-quick-card h3{
    font-size:18px !important;
  }

  .home-page .home-quick-card p{
    font-size:13px !important;
    min-height:38px !important;
  }

  .home-page .home-quick-card button{
    height:42px !important;
    min-height:42px !important;
    font-size:14px !important;
  }
}

/* 작은 태블릿: 3 x 2 */
@media (min-width:641px) and (max-width:900px){
  .home-page .home-quick-cards,
  .home-page .home-quick-cards.home-quick-cards-field{
    grid-template-columns:repeat(3, minmax(0, 1fr)) !important;
    gap:12px !important;
  }

  .home-page .home-quick-card{
    min-height:178px !important;
  }
}

/* 모바일: 1열 */
@media (max-width:640px){
  .home-page .home-quick-cards,
  .home-page .home-quick-cards.home-quick-cards-field{
    grid-template-columns:1fr !important;
    gap:10px !important;
  }

  .home-page .home-quick-card{
    min-height:0 !important;
    display:grid !important;
    grid-template-columns:48px minmax(0, 1fr) 92px !important;
    grid-template-areas:
      "icon title button"
      "icon desc button" !important;
    align-items:center !important;
    gap:4px 10px !important;
    text-align:left !important;
    padding:14px !important;
  }

  .home-page .home-quick-icon{
    grid-area:icon !important;
    margin:0 !important;
  }

  .home-page .home-quick-card h3{
    grid-area:title !important;
    margin:0 !important;
    font-size:18px !important;
  }

  .home-page .home-quick-card p{
    grid-area:desc !important;
    margin:0 !important;
    min-height:0 !important;
    font-size:13px !important;
  }

  .home-page .home-quick-card button{
    grid-area:button !important;
    width:92px !important;
    height:42px !important;
    min-height:42px !important;
    font-size:13px !important;
  }
}

/* ---------- PROGRESS: 삭제/저장 버튼 오른쪽 하단 정렬 ---------- */
.progress-v10-modal .progress-btn-row,
.progress-v10-modal .progress-modal-actions,
.progress-v10-modal .progress-v10-save-row,
.progress-v10-modal .progress-btn-row.progress-modal-actions.progress-v10-save-row,
.progress-modal.peon-popup-modal.progress-v10-modal .progress-btn-row,
.progress-modal.peon-popup-modal.progress-v10-modal .progress-modal-actions,
.progress-modal.peon-popup-modal.progress-v10-modal .progress-v10-save-row{
  display:flex !important;
  flex-direction:row !important;
  justify-content:flex-end !important;
  align-items:center !important;
  gap:12px !important;
  width:100% !important;
  padding:16px 32px 24px !important;
  margin:0 !important;
  box-sizing:border-box !important;
  background:#ffffff !important;
  border-top:1px solid #e5eaf3 !important;
  position:sticky !important;
  bottom:0 !important;
  z-index:10 !important;
}

.progress-v10-modal .progress-btn-row > button,
.progress-v10-modal .progress-modal-actions > button,
.progress-v10-modal .progress-v10-save-row > button,
.progress-v10-modal button.progress-delete-btn,
.progress-v10-modal button.progress-save-btn{
  flex:0 0 auto !important;
  width:auto !important;
  max-width:none !important;
  margin:0 !important;
  position:static !important;
}

.progress-v10-modal button.progress-delete-btn{
  min-width:140px !important;
  height:52px !important;
  border-radius:14px !important;
  border:1.5px solid #ef4444 !important;
  background:#ffffff !important;
  color:#dc2626 !important;
  font-size:17px !important;
  font-weight:900 !important;
}

.progress-v10-modal button.progress-save-btn{
  min-width:150px !important;
  height:52px !important;
  border-radius:14px !important;
  border:1.5px solid #2563eb !important;
  background:#2563eb !important;
  color:#ffffff !important;
  font-size:17px !important;
  font-weight:900 !important;
}

@media (max-width:768px){
  .progress-v10-modal .progress-btn-row,
  .progress-v10-modal .progress-modal-actions,
  .progress-v10-modal .progress-v10-save-row{
    justify-content:flex-end !important;
    padding:14px 18px 18px !important;
    gap:10px !important;
  }

  .progress-v10-modal button.progress-delete-btn,
  .progress-v10-modal button.progress-save-btn{
    min-width:118px !important;
    height:48px !important;
    font-size:15px !important;
  }
}
